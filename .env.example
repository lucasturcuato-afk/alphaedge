# .env.local — Copy to .env.local and fill in your values

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/alphaedge"

# ── Python Model Service ───────────────────────────────────────────────────────
PYTHON_MODEL_URL="http://localhost:8000"

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Data Sources (plug in real APIs here) ─────────────────────────────────────

# Stats APIs
# BALLDONTLIE_API_KEY="8cad4699-fda1-4fce-a6fe-1d0d0dad9e73"      # NBA stats — free tier available
# SPORTSRADAR_API_KEY="your_key"      # Premium stats + odds
# THE_ODDS_API_KEY="0247c46d6f0bfa69a741c96d4981fec0"         # Real-time sportsbook odds

# Social & News
# REDDIT_CLIENT_ID="your_id"
# REDDIT_SECRET="your_secret"
# TWITTER_BEARER_TOKEN="your_token"
# NEWS_API_KEY="your_key"             # newsapi.org

# MLB
# MLB_STATS_API="https://statsapi.mlb.com/api/v1"   # Free/public
# WEATHER_API_KEY="your_key"          # openweathermap.org

# ── App Config ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="AlphaEdge"
NEXT_PUBLIC_MODEL_VERSION="v2.1"
NODE_ENV="development"
